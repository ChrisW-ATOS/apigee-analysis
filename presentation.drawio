        <mxCell id="c4t" value="Isolation Forest — Multivariate Detection" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=17;fontStyle=1;fontColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="164" y="476" width="620" height="30" as="geometry"/></mxCell>
        <mxCell id="c4b" value="Global model trained on 5 features per proxy per hour: [traffic_z, client_z, server_z, client_rate, server_rate]. Detects unusual combinations invisible to univariate Z-scores — e.g. traffic normal but error mix flips from 4xx to 5xx, or two correlated proxies suddenly diverge. Retrained daily. scikit-learn, zero new dependencies." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=13;fontColor=#A0A0C8;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="100" y="520" width="680" height="120" as="geometry"/></mxCell>

