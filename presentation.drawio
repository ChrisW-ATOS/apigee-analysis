        <mxCell id="c2b" value="Flags values beyond ±3σ on traffic volume, 4xx client error rate, and 5xx server error rate — independently per proxy per hour. Threshold: 0.3% false positive rate." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=13;fontColor=#A0A0C8;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="616" y="290" width="422" height="120" as="geometry"/></mxCell>

