        <mxCell id="c5t" value="Sustained Detection + Blast Radius" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=17;fontStyle=1;fontColor=#FFFFFF;" vertex="1" parent="1"><mxGeometry x="938" y="476" width="620" height="30" as="geometry"/></mxCell>
        <mxCell id="c5b" value="Consecutive anomalous hours tracked per proxy — sustained=true after 2+ hours. Eliminates alert fatigue from self-resolving blips. Blast radius query maps each anomalous proxy to every developer app and OpCo that called it, ranked by call volume." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=13;fontColor=#A0A0C8;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="874" y="520" width="680" height="120" as="geometry"/></mxCell>

